{
  "name": "dispatch-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:migrate": "node dist/src/database/migrate.js && node dist/src/server.js",
    "db:init": "tsx src/database/migrate.ts",
    "db:seed": "tsx src/database/seed.ts",
    "db:migrate-sqlite-to-neon": "tsx scripts/migrate-sqlite-to-neon.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.0.1",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "morgan": "^1.10.0",
    "pg": "^8.22.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.13.14",
    "@types/pg": "^8.20.0",
    "prisma": "^6.19.3",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
